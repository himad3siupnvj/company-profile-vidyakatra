# Supabase/PostgreSQL connection string.
# Supabase example:
# postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vidyakatra_cms"

# Session signing secret for CMS auth.
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Public production URL used by sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase Storage server-side upload config.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"
SUPABASE_STORAGE_BUCKET="cms-assets"
